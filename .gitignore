# =========================
# OS 및 에디터 설정
# =========================
# Mac OS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows OS
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
desktop.ini

# VS Code
.vscode/
*.code-workspace

# IntelliJ IDEA / Eclipse (Java 개발 에디터)
.idea/
*.iml
*.iws
.settings/
.project
.classpath

# =========================
# Frontend (HTML, CSS, JS, React)
# =========================
# Node.js 패키지
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json # (선택) yarn을 사용할 경우 npm lock 파일 무시

# 빌드 결과물
build/
dist/
.next/
out/

# 환경 변수 파일 (보안을 위해 반드시 무시)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# =========================
# Backend (Java, Spring Boot)
# =========================
# 컴파일된 클래스 파일
*.class

# Maven 빌드 폴더
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Gradle 빌드 폴더
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# 로그 파일
*.log